# BOS Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Usage (Linux/Mac):
#   cp .env.example .env
#   # Edit .env with your values
#   export $(grep -v '^#' .env | xargs)
#
# Usage (Windows PowerShell):
#   Copy-Item .env.example .env
#   # Edit .env with your values
#   Get-Content .env | ForEach-Object { if ($_ -notmatch '^#') { $v=$_.Split('=',2); [System.Environment]::SetEnvironmentVariable($v[0],$v[1]) } }

# ── Django Security ───────────────────────────────────────────
# Generate a strong key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
BOS_SECRET_KEY=bos-dev-key-replace-before-deployment

# Set to "false" in production
BOS_DEBUG=true

# Comma-separated list of allowed hostnames (e.g. bos.example.com,api.bos.io)
# Leave empty for local development
BOS_ALLOWED_HOSTS=

# ── Database (PostgreSQL) ─────────────────────────────────────
BOS_DB_NAME=bos_project
BOS_DB_USER=postgres
BOS_DB_PASSWORD=your-db-password-here
BOS_DB_HOST=localhost
BOS_DB_PORT=5432
